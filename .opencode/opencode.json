{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": {
      "*": "ask",
      "**": "allow"
    },
    "write": {
      "*": "ask",
      "**": "allow"
    },
    "bash": {
      "*": "ask",
      "git *": "allow",
      "rm *": "deny",
      "rmdir *": "deny",
      "sudo *": "deny",
      "su *": "deny",
      "chmod 777 *": "deny",
      "chown *": "deny",
      "shred *": "deny",
      "wipe *": "deny",
      "unlink *": "deny",
      "truncate *": "deny"
    }
  },
  "plugin": [
    "oh-my-opencode@latest"
  ]
}
