{
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  },
  "permissions": {
    "allow": [
      "Read",
      "WebFetch",
      "Edit(/**)",
      "Bash(git *)"
    ],
    "ask": [
      "Bash(apt)",
      "Bash(dnf)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push --mirror *)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git branch --delete *)",
      "Bash(git tag -d *)",
      "Bash(git tag --delete *)",
      "Bash(git remote remove *)",
      "Bash(git remote rm *)",
      "Bash(git remote set-url *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git reflog expire *)",
      "Bash(git reflog delete *)",
      "Bash(git gc *)",
      "Bash(git prune *)",
      "Bash(git filter-branch *)",
      "Bash(git filter-repo *)",

      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(shred *)",
      "Bash(wipe *)",
      "Bash(unlink *)",
      "Bash(truncate *)",

      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)"
    ]
  }
}
